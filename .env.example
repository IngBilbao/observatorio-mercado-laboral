# Plantilla de variables de entorno. Copiar a .env y rellenar con valores reales.
# El archivo .env NUNCA se versiona (esta en .gitignore).

# ──────────── Credenciales Adzuna API ────────────
# Obtener en: https://developer.adzuna.com/admin/access_details
# Free tier: 1000 calls/mes, 25 resultados por llamada.
ADZUNA_APP_ID=tu_application_id_aqui
ADZUNA_APP_KEY=tu_api_key_aqui

# ──────────── Kaggle ────────────
# Normalmente Kaggle usa ~/.kaggle/kaggle.json y NO requiere estas variables.
# Solo defínelas si vas a forzar el uso desde código.
# KAGGLE_USERNAME=
# KAGGLE_KEY=
