# ──────────── Python ────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# ──────────── Datos ────────────
# No versionar datasets crudos pesados ni outputs generados.
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/outputs/*
!data/outputs/.gitkeep

# ──────────── Excel / Power BI temporales ────────────
~$*.xlsx
~$*.xlsm
*.pbix.bak
*.pbix.lock

# ──────────── Credenciales y secretos ────────────
.env
.env.*
!.env.example
*.key
*.pem
kaggle.json
adzuna_credentials.json
config_local.py
secrets/

# ──────────── IDE / SO ────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ──────────── Logs ────────────
logs/*
!logs/.gitkeep
*.log
